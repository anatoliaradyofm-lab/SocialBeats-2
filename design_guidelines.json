        "https://images.unsplash.com/photo-1768936919089-857e18c38cf5?crop=entropy&cs=srgb&fm=jpg&ixid=M3w4NTYxOTF8MHwxfHNlYXJjaHwzfHxhYnN0cmFjdCUyMG5lb24lMjBtdXNpYyUyMHdhdmUlMjBiYWNrZ3JvdW5kfGVufDB8fHx8MTc3MDY1MzA1M3ww&ixlib=rb-4.1.0&q=85",
        "https://images.unsplash.com/photo-1769123014694-de11a58232a3?crop=entropy&cs=srgb&fm=jpg&ixid=M3w4NTYxOTF8MHwxfHNlYXJjaHw0fHxhYnN0cmFjdCUyMG5lb24lMjBtdXNpYyUyMHdhdmUlMjBiYWNrZ3JvdW5kfGVufDB8fHx8MTc3MDY1MzA1M3ww&ixlib=rb-4.1.0&q=85"
