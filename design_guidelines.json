    "icons": {
      "library": "lucide-react",
      "preferred_set": "Play, Pause, SkipForward, SkipBack, Shuffle, Repeat, Heart, ListMusic, Search, Home, User, Settings, LogOut, Plus, MoreVertical"
    }
  },
  "instructions_to_main_agent": {
    "setup": [
      "Update /app/frontend/src/index.css with the provided HSL color variables for the 'dark' class.",
      "Add the Google Fonts import to /app/frontend/src/index.css.",
      "Configure tailwind.config.js to extend the font family with 'Outfit' (heading) and 'Inter' (body).",
      "Ensure 'lucide-react' is installed."
    ],
    "implementation_rules": [
      "ALWAYS use the 'dark' class on the root element or body to enforce dark mode.",
      "Use 'bg-background' for the main page background.",
      "Implement the 'Unified Player' as a fixed bottom bar with glassmorphism effects.",
      "Use 'sonner' for all toast notifications.",
      "Ensure all interactive elements have 'data-testid' attributes.",
      "Do NOT use gradients for text. Keep text high-contrast (white/zinc-400).",
      "Use the provided image URLs for mock data in the dashboard and library."
    ]
  },
  "universal_guidelines": {
    "design_philosophy": "Fusion over Imitation. Emotion First. Content is King.",
    "anti_patterns": [
      "Purple/Teal for CTA (Use Violet/Cyan instead)",
      "Inter everywhere (Use Outfit for headings)",
      "Center-Everything Disease (Use asymmetry)",
      "Gradient Overload (Use subtle glows/noise instead)"
    ],
    "accessibility": {
      "contrast": "Ensure 4.5:1 for normal text, 3:1 for large text.",
      "interactive": "Focus states must be visible and distinct."
    },
    "motion": {
      "micro_interactions": "Hover states, active states, and focus rings are mandatory.",
      "transitions": "Use 'transition-all duration-200 ease-in-out' for smooth feel."
    }
  }
}