# ============== REQUIRED ==============
# MongoDB connection string. Get from MongoDB Atlas or use local: mongodb://localhost:27017
MONGO_URL=mongodb://localhost:27017
# Database name
DB_NAME=socialbeats
# Secret for JWT signing. Generate with: openssl rand -hex 32
JWT_SECRET=your-secret-key-change-in-production

# ============== MUSIC ==============
# YouTube Data API v3. Get: Google Cloud Console > APIs & Services > Enable "YouTube Data API v3" > Credentials > Create API key
# If empty: uses oEmbed + yt-dlp fallback (no key needed, limited search)
YOUTUBE_API_KEY=

# Spotify Developer Dashboard: https://developer.spotify.com/dashboard > Create app > Client ID & Client Secret
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# OAuth callback URL (must match Spotify app settings, e.g. http://localhost:8080/callback)
SPOTIFY_REDIRECT_URI=http://localhost:8080/callback

# ============== AUTH ==============
# Firebase Console > Project Settings > General > Your apps
FIREBASE_PROJECT_ID=
FIREBASE_WEB_API_KEY=

# Google OAuth (for Google Sign-In). Same project as YouTube or create OAuth 2.0 credentials
# Get: Google Cloud Console > APIs & Services > Credentials > Create OAuth client ID
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ============== MODERATION ==============
# Detoxify (open source) - text toxicity. Score above this = unsafe. Range 0–1.
# NudeNet (open source) - image moderation. No API key needed.
DETOXIFY_TOXICITY_THRESHOLD=0.5

# ============== EMAIL (Brevo SMTP) ==============
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=SocialBeats <noreply@socialbeats.app>

# ============== SEARCH ==============
# Meilisearch (open-source, free). Install: curl -L https://install.meilisearch.com | sh
# Docker: docker run -p 7700:7700 getmeili/meilisearch
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_MASTER_KEY=

# ============== OTHER ==============
# GIPHY API: https://developers.giphy.com/ > Create app > API key
GIPHY_API_KEY=

# WebAuthn (passkeys). RP ID = your domain (e.g. localhost for dev)
WEBAUTHN_RP_ID=
WEBAUTHN_ORIGIN=

# Frontend URL (for CORS, redirects)
FRONTEND_URL=https://localhost

# ============== OPTIONAL INFRASTRUCTURE ==============
# PostgreSQL (analytics, sessions, audit)
POSTGRES_URL=postgresql://user:pass@localhost:5432/socialbeats

# Redis (cache, rate limit, sessions)
REDIS_URL=redis://localhost:6379

# ClickHouse (analytics)
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DB=socialbeats

# LiveKit (WebRTC voice/video)
LIVEKIT_URL=wss://your-livekit.example.com
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Cloudflare R2 (ana) - S3 uyumlu
R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=socialbeats
R2_PUBLIC_URL=

# MinIO (yedek - S3-compatible storage)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=socialbeats

# Google Gemini (AI metin - ana)
GEMINI_API_KEY=

# SuperTokens (auth - yedek, NextAuth web için)
SUPERTOKENS_CONNECTION_URI=
SUPERTOKENS_API_KEY=

# Trench (event tracking - ana)
TRENCH_URL=
TRENCH_API_KEY=

# Jitsu (event tracking - yedek)
JITSU_HOST=
JITSU_WRITE_KEY=
JITSU_SERVER_TOKEN=

# Umami (analytics)
UMAMI_URL=
UMAMI_WEBSITE_ID=
UMAMI_API_TOKEN=

# HuggingFace (AI: sentiment, language detection)
HF_API_TOKEN=

# Evolution API (WhatsApp)
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=socialbeats

# Grafana (monitoring)
GRAFANA_URL=
GRAFANA_API_KEY=

# Freesound (bildirim sesleri - sınırsız)
FREESOUND_API_KEY=
